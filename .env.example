# GEMINI_API_KEY: Required for Gemini AI API calls (optional for this app)
GEMINI_API_KEY=""

# VITE_API_BASE_URL: Root of the incident_report_backend (NO trailing slash, NO /api suffix).
# Routes mount as follows on the backend:
#   /auth/*            (no /api prefix)
#   /issues/*          (no /api prefix)
#   /api/admin/*
#   /api/technician/*
# - Production: https://incident-report-backend-cyep.onrender.com
# - Local dev:  http://localhost:3000
VITE_API_BASE_URL="https://incident-report-backend-cyep.onrender.com"
