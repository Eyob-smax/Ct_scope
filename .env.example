# GEMINI_API_KEY: Required for Gemini AI API calls (optional for this app)
GEMINI_API_KEY=""

# VITE_API_BASE_URL: Base URL of the incident report backend API (NO trailing /api)
# - Development: http://localhost:3000 (when backend runs on port 3000)
# - Staging: https://staging-api.example.com
# - Production: https://api.example.com
# Empty string uses same-origin requests (works with Vite proxy in dev)
VITE_API_BASE_URL="http://localhost:3000"
